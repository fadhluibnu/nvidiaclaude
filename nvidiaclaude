#!/usr/bin/env bash
#
# nvidiaclaude - run Claude Code against NVIDIA NIM through a local adapter.
#
# Key resolution order:
#   1. stored config file          - set by config/token subcommands
#   2. NVIDIA_API_KEYS env var     - comma-separated keys, saved for next time
#   3. NVIDIA_API_KEY env var      - single key, saved for next time
#   4. interactive prompt          - asks for a key if needed
#
set -euo pipefail

CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/nvidiaclaude"
CONFIG_FILE="$CONFIG_DIR/config"
DEFAULT_ENDPOINT="https://integrate.api.nvidia.com/v1/chat/completions"
DEFAULT_MODEL="minimaxai/minimax-m3"
LOCAL_AUTH_TOKEN="nvidiaclaude-local"
DEFAULT_INSTALL_REF="main"

say() { printf '%s\n' "$*" >&2; }

trim() {
  local s="$1"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

script_dir() {
  local source="${BASH_SOURCE[0]}"
  while [ -L "$source" ]; do
    local dir
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    source="$(readlink "$source")"
    case "$source" in
      /*) ;;
      *) source="$dir/$source" ;;
    esac
  done
  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

install_ref() {
  local ref_file ref
  ref_file="$(script_dir)/.nvidiaclaude-install-ref"
  if [ -n "${NVIDIACLAUDE_INSTALL_REF:-}" ]; then
    printf '%s' "$(trim "$NVIDIACLAUDE_INSTALL_REF")"
  elif [ -f "$ref_file" ]; then
    ref="$(tr -d '\r\n ' < "$ref_file")"
    if [ -n "$ref" ]; then
      printf '%s' "$ref"
    else
      printf '%s' "$DEFAULT_INSTALL_REF"
    fi
  else
    printf '%s' "$DEFAULT_INSTALL_REF"
  fi
}

read_config_value() {
  local name="$1" line
  [ -f "$CONFIG_FILE" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      "$name"=*) printf '%s' "${line#*=}"; return 0 ;;
    esac
  done < "$CONFIG_FILE"
  return 0
}

parse_key_csv() {
  local value="$1" part old_ifs
  local parts=()
  old_ifs="$IFS"
  IFS=','
  read -r -a parts <<< "$value"
  IFS="$old_ifs"
  for part in "${parts[@]}"; do
    part="$(trim "$part")"
    [ -n "$part" ] && printf '%s\n' "$part"
  done
}

add_unique_token() {
  local token="$1" existing
  token="$(trim "$token")"
  [ -n "$token" ] || return 0
  for existing in "${TOKENS[@]:-}"; do
    [ "$existing" = "$token" ] && return 0
  done
  TOKENS+=("$token")
}

read_config_keys() {
  local line value
  [ -f "$CONFIG_FILE" ] || return 0
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      NVIDIA_API_KEY=*)
        value="$(trim "${line#NVIDIA_API_KEY=}")"
        [ -n "$value" ] && printf '%s\n' "$value"
        ;;
      NVIDIA_API_KEYS=*)
        parse_key_csv "${line#NVIDIA_API_KEYS=}"
        ;;
    esac
  done < "$CONFIG_FILE"
  return 0
}

load_config_keys() {
  local key
  TOKENS=()
  while IFS= read -r key || [ -n "$key" ]; do
    add_unique_token "$key"
  done < <(read_config_keys)
}

load_env_keys() {
  local key
  TOKENS=()
  if [ -n "${NVIDIA_API_KEYS:-}" ]; then
    while IFS= read -r key || [ -n "$key" ]; do
      add_unique_token "$key"
    done < <(parse_key_csv "$NVIDIA_API_KEYS")
  elif [ -n "${NVIDIA_API_KEY:-}" ]; then
    add_unique_token "$NVIDIA_API_KEY"
  fi
}

set_config_value() {
  local name="$1" value="$2" tmp line wrote=0
  value="$(trim "$value")"
  if [ -z "$value" ]; then
    say "Refusing to save an empty value for $name."
    return 1
  fi
  mkdir -p "$CONFIG_DIR"
  tmp="$(mktemp "$CONFIG_DIR/config.XXXXXX")"
  if [ -f "$CONFIG_FILE" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
      case "$line" in
        "$name"=*)
          if [ "$wrote" -eq 0 ]; then
            printf '%s=%s\n' "$name" "$value" >> "$tmp"
            wrote=1
          fi
          ;;
        *)
          printf '%s\n' "$line" >> "$tmp"
          ;;
      esac
    done < "$CONFIG_FILE"
  fi
  if [ "$wrote" -eq 0 ]; then
    printf '%s=%s\n' "$name" "$value" >> "$tmp"
  fi
  chmod 600 "$tmp"
  mv "$tmp" "$CONFIG_FILE"
}

save_keys() {
  local tmp line key existing duplicate
  local keys=()
  for key in "$@"; do
    key="$(trim "$key")"
    [ -n "$key" ] || continue
    duplicate=0
    for existing in "${keys[@]:-}"; do
      if [ "$existing" = "$key" ]; then
        duplicate=1
        break
      fi
    done
    [ "$duplicate" -eq 0 ] && keys+=("$key")
  done
  if [ "${#keys[@]}" -eq 0 ]; then
    say "Refusing to save an empty token list."
    return 1
  fi

  mkdir -p "$CONFIG_DIR"
  tmp="$(mktemp "$CONFIG_DIR/config.XXXXXX")"
  if [ -f "$CONFIG_FILE" ]; then
    while IFS= read -r line || [ -n "$line" ]; do
      case "$line" in
        NVIDIA_API_KEY=*|NVIDIA_API_KEYS=*) ;;
        *) printf '%s\n' "$line" >> "$tmp" ;;
      esac
    done < "$CONFIG_FILE"
  fi
  for key in "${keys[@]}"; do
    printf 'NVIDIA_API_KEY=%s\n' "$key" >> "$tmp"
  done
  chmod 600 "$tmp"
  mv "$tmp" "$CONFIG_FILE"

  if [ "${#keys[@]}" -eq 1 ]; then
    say "Token saved to $CONFIG_FILE"
  else
    say "${#keys[@]} tokens saved to $CONFIG_FILE"
  fi
}

remove_config_value() {
  local name="$1" tmp line
  [ -f "$CONFIG_FILE" ] || return 0
  tmp="$(mktemp "$CONFIG_DIR/config.XXXXXX")"
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      "$name"=*) ;;
      *) printf '%s\n' "$line" >> "$tmp" ;;
    esac
  done < "$CONFIG_FILE"
  chmod 600 "$tmp"
  mv "$tmp" "$CONFIG_FILE"
}

remove_all_keys() {
  local tmp line
  [ -f "$CONFIG_FILE" ] || return 0
  tmp="$(mktemp "$CONFIG_DIR/config.XXXXXX")"
  while IFS= read -r line || [ -n "$line" ]; do
    case "$line" in
      NVIDIA_API_KEY=*|NVIDIA_API_KEYS=*) ;;
      *) printf '%s\n' "$line" >> "$tmp" ;;
    esac
  done < "$CONFIG_FILE"
  chmod 600 "$tmp"
  mv "$tmp" "$CONFIG_FILE"
}

save_key() {
  save_keys "$1"
}

save_model() {
  local model
  model="$(trim "$1")"
  if [ -z "$model" ]; then
    say "Refusing to save an empty model."
    return 1
  fi
  set_config_value NVIDIA_NIM_MODEL "$model"
  say "Model saved to $CONFIG_FILE"
}

configured_model() {
  local model
  model="$(read_config_value NVIDIA_NIM_MODEL)"
  if [ -n "${NVIDIA_NIM_MODEL:-}" ]; then
    printf '%s' "$(trim "$NVIDIA_NIM_MODEL")"
  elif [ -n "$model" ]; then
    printf '%s' "$(trim "$model")"
  else
    printf '%s' "$DEFAULT_MODEL"
  fi
}

read_secret() {
  local prompt="$1" value=""
  printf '%s' "$prompt" >&2
  if IFS= read -rs value 2>/dev/null < /dev/tty; then
    :
  else
    IFS= read -rs value || true
  fi
  printf '\n' >&2
  printf '%s' "$value"
}

join_keys() {
  local IFS=','
  printf '%s' "$*"
}

mask_key() {
  local key="$1" len head tail
  len="${#key}"
  if [ "$len" -le 10 ]; then
    printf '****'
    return
  fi
  head="${key:0:6}"
  tail="${key:$((len - 4)):4}"
  printf '%s...%s' "$head" "$tail"
}

interactive_setup() {
  say ""
  say "+------------------------------------------+"
  say "|  nvidiaclaude - first-time setup         |"
  say "+------------------------------------------+"
  say ""
  say "Claude Code will run against NVIDIA NIM."
  say "You only need to enter your NVIDIA API key once."
  say "Additional tokens can be added later with: nvidiaclaude token add"
  say ""
  local key="" tries=0
  while :; do
    key="$(trim "$(read_secret 'NVIDIA API key: ')")"
    [ -n "$key" ] && break
    tries=$((tries + 1))
    say "Key can't be empty."
    if [ "$tries" -ge 3 ]; then
      say "Aborting after 3 empty attempts."
      exit 1
    fi
  done
  save_key "$key"
  say ""
}

token_usage() {
  say "Usage:"
  say "  nvidiaclaude token add [KEY]"
  say "  nvidiaclaude token list"
  say "  nvidiaclaude token remove <INDEX>"
  say "  nvidiaclaude token clear"
}

token_command() {
  local action="${2:-list}" key existing index
  local next=()
  case "$action" in
    add)
      if [ "${3:-}" != "" ]; then
        key="$(trim "$3")"
      else
        key="$(trim "$(read_secret 'NVIDIA API key: ')")"
      fi
      if [ -z "$key" ]; then
        say "Token can't be empty."
        exit 1
      fi
      load_config_keys
      for existing in "${TOKENS[@]:-}"; do
        if [ "$existing" = "$key" ]; then
          say "Token already exists: $(mask_key "$key")"
          exit 0
        fi
      done
      TOKENS+=("$key")
      save_keys "${TOKENS[@]}"
      ;;
    list|ls)
      load_config_keys
      if [ "${#TOKENS[@]}" -eq 0 ]; then
        printf '%s\n' "No stored NVIDIA API tokens."
      else
        local i=1
        for key in "${TOKENS[@]}"; do
          printf '%d. %s\n' "$i" "$(mask_key "$key")"
          i=$((i + 1))
        done
      fi
      ;;
    remove|rm|delete)
      index="${3:-}"
      if ! [[ "$index" =~ ^[0-9]+$ ]] || [ "$index" -lt 1 ]; then
        say "Token index must be a positive number."
        token_usage
        exit 1
      fi
      load_config_keys
      if [ "$index" -gt "${#TOKENS[@]}" ]; then
        say "No token exists at index $index."
        exit 1
      fi
      local i=1
      for key in "${TOKENS[@]}"; do
        if [ "$i" -ne "$index" ]; then
          next+=("$key")
        fi
        i=$((i + 1))
      done
      if [ "${#next[@]}" -eq 0 ]; then
        remove_all_keys
        say "All stored tokens removed."
      else
        save_keys "${next[@]}"
      fi
      ;;
    clear|reset)
      remove_all_keys
      say "All stored tokens removed."
      ;;
    help|--help|-h)
      token_usage
      ;;
    *)
      say "Unknown token command: $action"
      token_usage
      exit 1
      ;;
  esac
}

show_commands() {
  cat <<EOF
nvidiaclaude command reference

Start
  nvidiaclaude [CLAUDE_ARGS...]
      Start Claude Code through the local NVIDIA NIM adapter.
      Any extra arguments are passed through to the claude CLI.

API key
  nvidiaclaude config <KEY>
      Replace the stored token list with one NVIDIA API token.

  nvidiaclaude change-key [KEY]
      Replace the stored token list. If KEY is omitted, nvidiaclaude asks
      for it securely.
      Aliases: config, set-key, change

  nvidiaclaude token add [KEY]
      Add another NVIDIA API token for automatic failover.

  nvidiaclaude token list
      List saved tokens with masked values.

  nvidiaclaude token remove <INDEX>
      Remove one saved token by index from token list.

  nvidiaclaude token clear
      Remove all saved tokens. The stored model is kept.

  nvidiaclaude reset
      Remove all saved tokens. The stored model is kept.

Model
  nvidiaclaude change-model <MODEL>
      Save the NVIDIA NIM model used by future nvidiaclaude runs.

  nvidiaclaude set-model <MODEL>
      Alias for change-model.

  nvidiaclaude model
      Show the model new runs will use after applying env/config/default
      precedence.

  nvidiaclaude reset-model
      Remove the stored model and return to the default model:
      $DEFAULT_MODEL

Maintenance
  nvidiaclaude update
      Re-run the installer from the selected install branch.
      Aliases: upgrade

  nvidiaclaude commands
      Show this command reference.
      Aliases: help, --help-nvidiaclaude

Environment overrides
  NVIDIA_API_KEY
      Use this token if no token is stored yet. It will be saved for next time.

  NVIDIA_API_KEYS
      Comma-separated token list if no token is stored yet. It will be saved
      for next time.

  NVIDIA_NIM_MODEL
      Override the configured model for one run.

  NVIDIA_NIM_ENDPOINT
      Override the NVIDIA NIM endpoint for one run.
      Default: $DEFAULT_ENDPOINT

  NVIDIACLAUDE_STREAM_PING_SECONDS
      Send Anthropic SSE ping events while waiting for NVIDIA NIM stream
      chunks. Default: 2. Set to 0 to disable.

  NVIDIACLAUDE_TOKEN_COOLDOWN_SECONDS
      Seconds to avoid a token after a token-specific failure. Default: 60.

  NVIDIACLAUDE_RATE_LIMIT_RPM
      Maximum NVIDIA requests per token per rate-limit window. Default: 38.
      Set to 0 to disable proactive throttling.

  NVIDIACLAUDE_RATE_LIMIT_WINDOW_SECONDS
      Rate-limit window length in seconds. Default: 60.

  NVIDIACLAUDE_INSTALL_REF
      Override the install/update branch for one install or update.

  NVIDIACLAUDE_BIN_DIR
      Override the install directory used by install.sh.

Config paths
  macOS/Linux:
      ${CONFIG_FILE}

  Windows:
      %APPDATA%\\nvidiaclaude\\config
EOF
}

find_python() {
  if command -v python3 >/dev/null 2>&1; then
    command -v python3
    return 0
  fi
  if command -v python >/dev/null 2>&1; then
    command -v python
    return 0
  fi
  return 1
}

cleanup_proxy() {
  if [ -n "${PROXY_PID:-}" ] && kill -0 "$PROXY_PID" >/dev/null 2>&1; then
    kill "$PROXY_PID" >/dev/null 2>&1 || true
    wait "$PROXY_PID" >/dev/null 2>&1 || true
  fi
  if [ -n "${TMP_DIR:-}" ] && [ -d "$TMP_DIR" ]; then
    rm -rf "$TMP_DIR"
  fi
}

start_proxy() {
  local python proxy_dir proxy_file ready_file log_file attempts port
  python="$(find_python)" || {
    say "Python 3 not found on PATH."
    say "Install Python 3 before running nvidiaclaude."
    exit 127
  }

  proxy_dir="$(script_dir)"
  proxy_file="$proxy_dir/nvidiaclaude_proxy.py"
  if [ ! -f "$proxy_file" ]; then
    say "Proxy file not found: $proxy_file"
    say "Reinstall nvidiaclaude so nvidiaclaude_proxy.py is installed next to the command."
    exit 1
  fi

  TMP_DIR="$(mktemp -d "${TMPDIR:-/tmp}/nvidiaclaude.XXXXXX")"
  ready_file="$TMP_DIR/ready"
  log_file="$TMP_DIR/proxy.log"

  "$python" "$proxy_file" \
    --host 127.0.0.1 \
    --port 0 \
    --ready-file "$ready_file" \
    > "$log_file" 2>&1 &
  PROXY_PID=$!

  attempts=0
  while [ ! -s "$ready_file" ]; do
    if ! kill -0 "$PROXY_PID" >/dev/null 2>&1; then
      say "nvidiaclaude proxy failed to start."
      [ -s "$log_file" ] && sed 's/^/  /' "$log_file" >&2
      exit 1
    fi
    attempts=$((attempts + 1))
    if [ "$attempts" -ge 200 ]; then
      say "Timed out waiting for nvidiaclaude proxy."
      [ -s "$log_file" ] && sed 's/^/  /' "$log_file" >&2
      exit 1
    fi
    sleep 0.05
  done

  port="$(tr -d '\r\n ' < "$ready_file")"
  if [ -z "$port" ]; then
    say "nvidiaclaude proxy did not report a port."
    exit 1
  fi
  printf '%s' "$port"
}

case "${1:-}" in
  commands|help|--help-nvidiaclaude)
    show_commands
    exit 0
    ;;
  config|--config|set-key|--set-key|change|--change|change-key|--change-key)
    if [ "${2:-}" != "" ]; then
      save_key "$2"
    else
      interactive_setup
    fi
    say "Done. Run 'nvidiaclaude' to start."
    exit 0
    ;;
  token|tokens)
    token_command "$@"
    exit 0
    ;;
  change-model|--change-model|set-model|--set-model)
    if [ "${2:-}" = "" ]; then
      say "Usage: nvidiaclaude change-model <MODEL>"
      exit 1
    fi
    save_model "$2"
    say "Done. New runs will use model: $(configured_model)"
    exit 0
    ;;
  model|--model|current-model|--current-model)
    printf '%s\n' "$(configured_model)"
    exit 0
    ;;
  reset-model|--reset-model)
    remove_config_value NVIDIA_NIM_MODEL
    say "Stored model removed. New runs will use default model: $DEFAULT_MODEL"
    exit 0
    ;;
  reset|--reset)
    remove_all_keys
    say "All stored tokens removed."
    exit 0
    ;;
  update|--update|upgrade|--upgrade)
    REF="$(install_ref)"
    say "Updating nvidiaclaude from '$REF'..."
    curl -fsSL "https://raw.githubusercontent.com/fadhluibnu/nvidiaclaude/$REF/install.sh" \
      | NVIDIACLAUDE_INSTALL_REF="$REF" bash
    exit $?
    ;;
esac

TOKENS=()
load_config_keys

if [ "${#TOKENS[@]}" -eq 0 ]; then
  load_env_keys
  if [ "${#TOKENS[@]}" -gt 0 ]; then
    say "Using NVIDIA API token(s) from environment; saving for next time."
    save_keys "${TOKENS[@]}" || true
  fi
fi

if [ "${#TOKENS[@]}" -eq 0 ]; then
  interactive_setup
  load_config_keys
fi

if [ "${#TOKENS[@]}" -eq 0 ]; then
  say "No API token available. Run 'nvidiaclaude token add' to set one."
  exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
  say "claude CLI not found on PATH."
  say "Install Claude Code first: https://docs.claude.com/en/docs/claude-code"
  exit 127
fi

export NVIDIA_API_KEY="${TOKENS[0]}"
export NVIDIA_API_KEYS="$(join_keys "${TOKENS[@]}")"
export NVIDIA_NIM_ENDPOINT="${NVIDIA_NIM_ENDPOINT:-$DEFAULT_ENDPOINT}"
export NVIDIA_NIM_MODEL="$(configured_model)"

trap cleanup_proxy EXIT INT TERM
PORT="$(start_proxy)"

export ANTHROPIC_BASE_URL="http://127.0.0.1:$PORT"
export ANTHROPIC_AUTH_TOKEN="$LOCAL_AUTH_TOKEN"
export ANTHROPIC_MODEL="$NVIDIA_NIM_MODEL"
export ANTHROPIC_DEFAULT_OPUS_MODEL="$NVIDIA_NIM_MODEL"
export ANTHROPIC_DEFAULT_SONNET_MODEL="$NVIDIA_NIM_MODEL"
export ANTHROPIC_DEFAULT_HAIKU_MODEL="$NVIDIA_NIM_MODEL"
export ANTHROPIC_SMALL_FAST_MODEL="$NVIDIA_NIM_MODEL"
export CLAUDE_CODE_SUBAGENT_MODEL="$NVIDIA_NIM_MODEL"
export CLAUDE_CODE_EFFORT_LEVEL="max"

claude --dangerously-skip-permissions "$@"
exit $?
